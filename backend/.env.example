# Required
OPENAI_API_KEY=sk-...

# Vector DB: "chroma" (local) or "pinecone" (production)
VECTOR_DB=chroma
CHROMA_PATH=./data/chroma

# Pinecone (only needed if VECTOR_DB=pinecone)
PINECONE_API_KEY=
PINECONE_INDEX=rag-engine

# PostgreSQL (optional - metadata storage)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_engine

# Redis (optional - response caching)
REDIS_URL=redis://localhost:6379
CACHE_TTL=3600

# LLM / Embedding models
OPENAI_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Retrieval tuning
TOP_K_VECTOR=10
TOP_K_BM25=10
TOP_K_RERANK=5
HYBRID_ALPHA=0.7

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64
